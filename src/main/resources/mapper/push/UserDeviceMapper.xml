<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.heang.koriaibackend.domain.push.mapper.UserDeviceMapper">

    <resultMap id="UserDeviceResultMap" type="com.heang.koriaibackend.domain.push.model.UserDevice">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="fcmToken" column="fcm_token"/>
        <result property="platform" column="platform"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="upsert" parameterType="com.heang.koriaibackend.domain.push.model.UserDevice">
        INSERT INTO user_devices (id, user_id, fcm_token, platform)
        VALUES (#{id}, #{userId}, #{fcmToken}, #{platform})
        ON CONFLICT (fcm_token)
        DO UPDATE SET user_id  = EXCLUDED.user_id,
                      platform = EXCLUDED.platform
    </insert>

    <select id="findByUserId" resultMap="UserDeviceResultMap">
        SELECT id, user_id, fcm_token, platform, created_at
        FROM user_devices
        WHERE user_id = #{userId}
    </select>

    <delete id="deleteByToken">
        DELETE FROM user_devices WHERE fcm_token = #{fcmToken}
    </delete>

</mapper>
