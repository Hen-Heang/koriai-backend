<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.heang.koriaibackend.domain.correction.mapper.SentenceCorrectionMapper">

    <resultMap id="SentenceCorrectionResultMap" type="com.heang.koriaibackend.domain.correction.model.SentenceCorrection">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="originalText" column="original_text"/>
        <result property="correctedText" column="corrected_text"/>
        <result property="explanation" column="explanation"/>
        <result property="grammarPoints" column="grammar_points"/>
        <result property="modelUsed" column="model_used"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.heang.koriaibackend.domain.correction.model.SentenceCorrection"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sentence_corrections (
            user_id,
            original_text,
            corrected_text,
            explanation,
            grammar_points,
            model_used
        ) VALUES (
            #{userId},
            #{originalText},
            #{correctedText},
            #{explanation},
            CAST(#{grammarPoints} AS jsonb),
            #{modelUsed}
        )
    </insert>

    <select id="findByUserId" resultMap="SentenceCorrectionResultMap">
        SELECT id, user_id, original_text, corrected_text, explanation, grammar_points, model_used, created_at
        FROM sentence_corrections
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
        LIMIT #{limit}
    </select>
</mapper>
