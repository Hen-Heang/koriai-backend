<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.heang.koriaibackend.domain.users.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.heang.koriaibackend.domain.users.model.User">
        <id property="id" column="id"/>
        <result property="email" column="email"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="displayName" column="display_name"/>
        <result property="koreanLevel" column="korean_level"/>
        <result property="preferredModel" column="preferred_model"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, email, password_hash, display_name, korean_level, preferred_model, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="com.heang.koriaibackend.domain.users.model.User"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (
            email,
            password_hash,
            display_name,
            korean_level,
            preferred_model
        ) VALUES (
            #{email},
            #{passwordHash},
            #{displayName},
            #{koreanLevel},
            #{preferredModel}
        )
    </insert>

    <select id="findById" resultMap="UserResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM users
        WHERE id = #{id}
    </select>

    <select id="findByEmail" resultMap="UserResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM users
        WHERE email = #{email}
    </select>

    <update id="updateProfile">
        UPDATE users
        SET display_name = #{displayName},
            korean_level = #{koreanLevel},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <update id="updatePreferredModel">
        UPDATE users
        SET preferred_model = #{preferredModel},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM users WHERE id = #{id}
    </delete>
</mapper>
